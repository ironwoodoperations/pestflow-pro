{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(?<subdomain>[^.]+)\\.pestflowpro\\.com"
        }
      ],
      "destination": "https://:subdomain.pestflowpro.ai/:path*",
      "permanent": false
    },
    { "source": "/accessibility/", "destination": "/", "permanent": true }
  ]
}
