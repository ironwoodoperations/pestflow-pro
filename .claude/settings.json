{
  "env": {
    "PESTFLOW_ENV": "development"
  },
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(curl *)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "mcp__claude_ai_Supabase__apply_migration",
      "Bash(git -C /workspaces/pestflow-pro log --oneline -10)",
      "Bash(wc -l src/shells/*/ShellHomeSections.tsx src/shells/*/ShellHero.tsx)",
      "Bash(wc -l src/components/admin/seo/*.tsx src/components/admin/seo/*.ts)",
      "Bash(supabase secrets:*)",
      "Bash(wc -l src/pages/*Control.tsx src/pages/BedBugControl.tsx src/pages/ScorpionControl.tsx src/pages/PestControlPage.tsx src/pages/TermiteInspections.tsx)",
      "Bash(wc -l src/shells/*/ShellHomeSections.tsx)",
      "Bash(nslookup lonestarpest.pestflowpro.com)",
      "mcp__claude_ai_Supabase__get_publishable_keys",
      "Bash(rm -rf node_modules*)",
      "Bash(rm -rf .next*)",
      "Bash(rm -rf public/_admin*)",
      "Bash(rm -rf dist*)",
      "Bash(gh pr *)",
      "Bash(gh repo *)",
      "Bash(git push -u origin *)",
      "Bash(git push origin *)",
      "Bash(git tag *)",
      "Bash(chmod *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(rm -rf *)",
      "Bash(git branch -D *)",
      "Bash(vercel deploy --prod)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/require-pr.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-end.sh"
          }
        ]
      }
    ]
  }
}
