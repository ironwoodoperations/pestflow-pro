{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],
    "allowJs": true,
    "incremental": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "esnext"]
  },
  "include": [
    "app/**/*",
    "shared/**/*",
    "middleware.ts",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["src/**/*", "node_modules", ".next", "dist", "public"]
}
